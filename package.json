{
	"name": "bpmn-flash",
	"version": "1.0.0",
	"description": "A lightweight and fast BPMN 2.0 engine implementation for JavaScript and TypeScript",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "rolldown -c rolldown.config.ts",
		"dev": "rolldown -c rolldown.config.ts --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint src/**/*.ts",
		"lint:fix": "eslint src/**/*.ts --fix",
		"format": "prettier --write src/**/*.ts",
		"format:check": "prettier --check src/**/*.ts",
		"prepare": "husky install",
		"pre-commit": "npm run format && npm run lint",
		"debug": "ts-node debug.ts || tsc --target ES2020 --module commonjs --moduleResolution node debug.ts && node debug.js"
	},
	"keywords": [
		"bpmn",
		"workflow",
		"engine",
		"business-process",
		"typescript"
	],
	"author": "BPMN Flash Contributors",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.10.0",
		"@rollup/plugin-typescript": "^11.1.6",
		"@types/node": "^22.5.0",
		"@vitest/coverage-v8": "^1.6.0",
		"eslint": "^9.10.0",
		"husky": "^9.1.5",
		"prettier": "^3.3.3",
		"rolldown": "^0.15.0",
		"tslib": "^2.7.0",
		"tsx": "^4.21.0",
		"typescript": "^5.5.4",
		"typescript-eslint": "^8.4.0",
		"vitest": "^1.6.0"
	},
	"files": [
		"dist/"
	],
	"dependencies": {
		"fast-xml-parser": "^5.5.6",
		"zod": "^4.3.6"
	}
}
